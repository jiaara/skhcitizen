function sharePost(element) {
  var shareTitle = element.getAttribute('data-title');
  var shareUrl = element.getAttribute('data-url');

  if (navigator.share) {
    // Fungsi Share Native untuk HP / Browser Modern
    navigator.share({
      title: shareTitle,
      url: shareUrl
    }).then(() => {
      console.log('Thanks for sharing!');
    })
    .catch(console.error);
  } else {
    // Fallback: Jika browser tidak mendukung Web Share (seperti Desktop lama)
    // Akan membuka popup window ke pilihan social media sederhana
    var fbShare = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(shareUrl);
    window.open(fbShare, 'sharer', 'toolbar=0,status=0,width=648,height=441');
  }
}
